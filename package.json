{
  "name": "opendocu",
  "version": "1.0.1",
  "description": "Coding-agent plugin and deterministic local documentation search.",
  "type": "module",
  "author": "OpenDocu contributors",
  "homepage": "https://github.com/yu2001-s/OpenDocu#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yu2001-s/OpenDocu.git"
  },
  "bugs": {
    "url": "https://github.com/yu2001-s/OpenDocu/issues"
  },
  "bin": {
    "opendocu": "./bin/opendocu.mjs"
  },
  "files": [
    "bin/",
    "src/",
    "skills/",
    ".codex-plugin/",
    ".claude-plugin/",
    "commands/",
    "AGENTS.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node --test",
    "build:plugin": "node scripts/build_plugin_bundle.mjs",
    "validate:repo": "node scripts/validate_repo.mjs",
    "check": "npm test && npm run validate:repo && node bin/opendocu.mjs --help",
    "gate:fixture": "node scripts/release_gate.mjs",
    "gate:normalization": "node scripts/source_normalization_gate.mjs",
    "gate:workflow-sim": "node scripts/workflow_sim_gate.mjs",
    "gate:package": "node scripts/package_smoke.mjs",
    "gate:real": "node scripts/real_node_gate.mjs",
    "gate:html": "node scripts/real_html_gate.mjs",
    "gate:network": "npm run gate:real && npm run gate:html",
    "gate:all": "npm run gate:fixture && npm run gate:normalization && npm run gate:workflow-sim && npm run gate:package && npm run gate:network",
    "gate:release": "npm run check && npm run gate:all",
    "eval:live:plan": "node scripts/live_agent_eval.mjs plan",
    "eval:live:score": "node scripts/live_agent_eval.mjs score"
  },
  "engines": {
    "node": ">=24"
  },
  "keywords": [
    "coding-agent",
    "documentation",
    "search",
    "local-first",
    "codex-plugin",
    "claude-code-plugin"
  ],
  "license": "MIT"
}
